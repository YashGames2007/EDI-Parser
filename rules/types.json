{
    "N1": {
        "regex": "^[1-2]{1}$"
    },
    "ID2": {
        "regex": "^[A-Z0-9]{2}$"
    },
    "ID3": {
        "regex": "^[A-Z0-9]{3}$"
    },
    "AN1_80": {
        "regex": "^[A-Za-z0-9 .\\-]{1,80}$"
    },
    "ANS15": {
        "regex": "^.{1,15}$"
    },
    "N0_9": {
        "regex": "^[0-9]{1,9}$"
    },
    "DT8": {
        "regex": "^[0-9]{8}$",
        "format": "CCYYMMDD",
        "type": "date"
    },
    "DT6": {
        "regex": "^[0-9]{6}$",
        "format": "YYMMDD",
        "type": "date"
    },
    "TM4": {
        "regex": "^[0-9]{4}$",
        "format": "HHMM",
        "type": "time"
    },
    "CHAR": {
        "regex": "^.$"
    },
    "SPACE10": {
        "regex": "^\\s{10}$"
    },
    "AN10": {
        "regex": "^.{1,10}$"
    }
}